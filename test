-- ============================================================
--  COMET HUB - DUMP ALL TO FILE (writefile)
--  Ecrit le résultat dans workspace/comet_dump.txt
--  Puis affiche une notif quand c'est fait
-- ============================================================

local RS = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local StarterGui = game:GetService("StarterGui")
local player = Players.LocalPlayer
local output = {}

local function add(line)
    table.insert(output, tostring(line))
end

add("=== COMET HUB FULL DUMP ===")
add("Player: " .. player.Name .. " | DisplayName: " .. player.DisplayName)
add("")

-- ============================================================
-- 1. Structure complète OfflineBooths
-- ============================================================
add("--- [1] ReplicatedStorage.OfflineBooths structure ---")
local ob = RS:FindFirstChild("OfflineBooths")
if ob then
    for _, child in ipairs(ob:GetDescendants()) do
        add(child.ClassName .. " | " .. child:GetFullName())
    end
else
    add("OfflineBooths NOT FOUND in ReplicatedStorage")
end

add("")

-- ============================================================
-- 2. Attributes sur chaque Item dans OfflineBooths
-- ============================================================
add("--- [2] Attributes on each Item ---")
if ob then
    for _, item in ipairs(ob:GetDescendants()) do
        local attrs = item:GetAttributes()
        local count = 0
        for _ in pairs(attrs) do count = count + 1 end
        if count > 0 then
            local attrStr = ""
            for k, v in pairs(attrs) do
                attrStr = attrStr .. k .. "=" .. tostring(v) .. " "
            end
            add(item:GetFullName() .. " | ATTRS: " .. attrStr)
        end
    end
end

add("")

-- ============================================================
-- 3. BoothUI owner texts (tous les booths)
-- ============================================================
add("--- [3] BoothUI all owner texts ---")
local boothlocation = nil
pcall(function()
    boothlocation = player
        :WaitForChild("PlayerGui", 5)
        :WaitForChild("MapUIContainer", 5)
        :WaitForChild("MapUI", 5)
end)

if boothlocation then
    local boothUI = boothlocation:FindFirstChild("BoothUI")
    if boothUI then
        for _, f in ipairs(boothUI:GetChildren()) do
            if f:FindFirstChild("Details") then
                local ownerLabel = f.Details:FindFirstChild("Owner")
                local ownerText = ownerLabel and ownerLabel.Text or "NIL"
                add("Booth: " .. f.Name .. " | Owner: '" .. ownerText .. "'")
                -- aussi lister les attributes du booth UI frame
                for k, v in pairs(f:GetAttributes()) do
                    add("  ATTR: " .. k .. " = " .. tostring(v))
                end
            end
        end
    else
        add("BoothUI not found inside MapUI")
    end
else
    add("boothlocation = NIL")
end

add("")

-- ============================================================
-- 4. BoothInteractions workspace attributes
-- ============================================================
add("--- [4] BoothInteractions attributes ---")
local bi = workspace:FindFirstChild("BoothInteractions")
if bi then
    for _, interact in ipairs(bi:GetChildren()) do
        local attrStr = ""
        for k, v in pairs(interact:GetAttributes()) do
            attrStr = attrStr .. k .. "=" .. tostring(v) .. " "
        end
        add(interact.Name .. " | CLASS: " .. interact.ClassName .. " | ATTRS: " .. attrStr)
    end
else
    add("BoothInteractions NOT FOUND in workspace")
end

add("")

-- ============================================================
-- 5. Remotes module keys
-- ============================================================
add("--- [5] Remotes module ---")
for _, v in pairs(RS:GetChildren()) do
    if v.Name:find("Remote") and v:IsA("ModuleScript") then
        local ok, mod = pcall(require, v)
        if ok and mod and type(mod) == "table" then
            add("Module: " .. v.Name)
            for key, val in pairs(mod) do
                add("  key: " .. tostring(key) .. " -> " .. type(val))
            end
        end
    end
end

add("")
add("=== END OF DUMP ===")

-- Ecrire dans un fichier
local content = table.concat(output, "\n")
local success = pcall(writefile, "comet_dump.txt", content)
if success then
    pcall(function()
        StarterGui:SetCore("SendNotification", {
            Title = "Dump OK!",
            Text = "Fichier comet_dump.txt créé! Envoie le fichier à Mathéo",
            Duration = 10,
        })
    end)
    print("DUMP WRITTEN TO: comet_dump.txt (" .. #output .. " lines)")
else
    -- Fallback: print tout dans la console
    pcall(function()
        StarterGui:SetCore("SendNotification", {
            Title = "writefile indisponible",
            Text = "Résultats dans F9 console",
            Duration = 5,
        })
    end)
    for _, line in ipairs(output) do
        print(line)
    end
end
