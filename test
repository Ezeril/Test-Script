local Players          = game:GetService("Players")
local TweenService     = game:GetService("TweenService")
local RunService       = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local Player           = Players.LocalPlayer

-- ─── STORAGE ──────────────────────────────────────────────
local LOG       = {}
local STATS     = {
    tweenMoves    = 0,
    directCframes = 0,
    velocityReset = 0,
    noclipToggles = 0,
    touchFires    = 0,
    gravityChange = 0,
    coinCollected = 0,
}
local TECHNIQUES = {}

local function log(cat, msg, important)
    local entry = string.format("[%s][%.2fs] %s", cat, tick() % 1000, msg)
    table.insert(LOG, entry)
    if important then
        warn(entry)
    else
        print(entry)
    end
end

local function detectTechnique(name)
    if not TECHNIQUES[name] then
        TECHNIQUES[name] = true
        log("✅ TECH", "Technique détectée : " .. name, true)
    end
end

-- ─── 1. HOOK TWEENSERVICE:CREATE ──────────────────────────
-- Détecte si Vertex utilise TweenService pour déplacer le HRP
local origCreate = TweenService.Create
TweenService.Create = function(self, instance, tweenInfo, props)
    if instance and instance:IsA("BasePart") then
        local isHRP = instance.Name == "HumanoidRootPart"
        local propsStr = ""
        for k, v in pairs(props) do
            propsStr = propsStr .. tostring(k) .. "=" .. tostring(v) .. " "
        end
        if isHRP or props.CFrame then
            STATS.tweenMoves += 1
            detectTechnique("TweenService CFrame")
            log("TWEEN", string.format(
                "%s | durée=%.3fs | style=%s | props={%s}",
                instance.Name, tweenInfo.Time,
                tostring(tweenInfo.EasingStyle), propsStr
            ))
        end
    end
    return origCreate(self, instance, tweenInfo, props)
end

-- ─── 2. HOOK HRP CFrame (direct assignment) ───────────────
-- Détecte les CFrame directs (hrp.CFrame = ...) 
-- Plus rapide que TweenService → technique anti-rollback
local function hookHRP(char)
    local hrp = char:WaitForChild("HumanoidRootPart", 5)
    if not hrp then return end

    local lastPos  = hrp.Position
    local lastTime = tick()

    hrp:GetPropertyChangedSignal("CFrame"):Connect(function()
        local now    = tick()
        local newPos = hrp.Position
        local delta  = (newPos - lastPos).Magnitude
        local dt     = now - lastTime

        -- Filtrer les micro-mouvements physiques normaux (<0.05 studs/frame)
        if delta > 0.15 and dt < 0.05 then
            -- Mouvement très rapide = override direct (pas physique)
            STATS.directCframes += 1
            detectTechnique("CFrame Direct (anti-rollback)")
            log("CFRAME", string.format(
                "Override direct | Δ=%.3f studs | dt=%.4fs | vitesse=%.1f stud/s",
                delta, dt, delta / math.max(dt, 0.001)
            ))
        end

        lastPos  = newPos
        lastTime = now
    end)

    -- ─── 3. HOOK AssemblyLinearVelocity ───────────────────
    -- Reset à zero = bloque les forces physiques de la map
    hrp:GetPropertyChangedSignal("AssemblyLinearVelocity"):Connect(function()
        local vel = hrp.AssemblyLinearVelocity
        if vel.Magnitude < 0.001 then
            STATS.velocityReset += 1
            if STATS.velocityReset <= 3 or STATS.velocityReset % 100 == 0 then
                detectTechnique("AssemblyLinearVelocity Reset (anti-physique)")
                log("VELOCITY", string.format(
                    "Velocity reset → zéro (total: %d fois)", STATS.velocityReset
                ))
            end
        end
    end)

    log("SPY", "✅ Hook HRP actif sur " .. Player.Name)
end

-- ─── 4. HOOK CANCOLLIDE (noclip) ──────────────────────────
-- Vertex désactive les collisions pour traverser les murs
local function monitorCanCollide(char)
    local function watch(part)
        if not part:IsA("BasePart") then return end
        part:GetPropertyChangedSignal("CanCollide"):Connect(function()
            if not part.CanCollide then
                STATS.noclipToggles += 1
                if STATS.noclipToggles <= 5 or STATS.noclipToggles % 50 == 0 then
                    detectTechnique("CanCollide = false (noclip)")
                    log("NOCLIP", string.format(
                        "%s.CanCollide désactivé (total: %d)", part.Name, STATS.noclipToggles
                    ))
                end
            end
        end)
    end
    for _, v in ipairs(char:GetDescendants()) do watch(v) end
    char.DescendantAdded:Connect(watch)
end

-- ─── 5. HOOK FIRETOUCHINTEREST ────────────────────────────
-- Vertex simule un toucher de coin sans vraiment se déplacer dessus
if firetouchinterest then
    local origFTI = firetouchinterest
    firetouchinterest = function(p1, p2, toggle)
        STATS.touchFires += 1
        detectTechnique("firetouchinterest (touch simulé)")
        log("TOUCH", string.format(
            "firetouchinterest(%s → %s, toggle=%d)",
            p1 and p1.Name or "?",
            p2 and p2.Name or "?",
            toggle
        ))
        return origFTI(p1, p2, toggle)
    end
else
    log("SPY", "firetouchinterest non disponible sur cet exploit")
end

-- ─── 6. HOOK WORKSPACE GRAVITY ────────────────────────────
-- Certains scripts mettent gravity=0 pour flotter librement
local lastGrav = workspace.Gravity
workspace:GetPropertyChangedSignal("Gravity"):Connect(function()
    local newGrav = workspace.Gravity
    STATS.gravityChange += 1
    detectTechnique("workspace.Gravity modifiée")
    log("GRAVITY", string.format(
        "Gravity: %.1f → %.1f", lastGrav, newGrav
    ), true)
    lastGrav = newGrav
end)

-- ─── 7. SURVEILLER COIN COLLECTED REMOTE ──────────────────
pcall(function()
    local rem = game.ReplicatedStorage
        :WaitForChild("Remotes", 3)
        :WaitForChild("Gameplay", 3)
        :WaitForChild("CoinCollected", 3)
    if rem then
        rem.OnClientEvent:Connect(function(...)
            STATS.coinCollected += 1
            log("COIN", string.format(
                "Pièce collectée (total: %d) | args: %s",
                STATS.coinCollected, tostring(select(1, ...))
            ))
        end)
        log("SPY", "✅ Hook CoinCollected actif")
    end
end)

-- ─── 8. SURVEILLER LES CONNEXIONS RUNSERVICE ──────────────
-- Compte les connexions Heartbeat/Stepped pour détecter des loops
local origHBConnect = RunService.Heartbeat.Connect
local hbConnCount = 0
RunService.Heartbeat.Connect = function(self, fn)
    hbConnCount += 1
    log("LOOP", string.format(
        "Nouvelle connexion Heartbeat (#%d)", hbConnCount
    ))
    detectTechnique("RunService.Heartbeat loop")
    return origHBConnect(self, fn)
end

local origSteppedConnect = RunService.Stepped.Connect
local steppedConnCount = 0
RunService.Stepped.Connect = function(self, fn)
    steppedConnCount += 1
    log("LOOP", string.format(
        "Nouvelle connexion Stepped (#%d)", steppedConnCount
    ))
    detectTechnique("RunService.Stepped loop")
    return origSteppedConnect(self, fn)
end

-- ─── 9. COMMANDES CLAVIER ─────────────────────────────────
UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end

    -- F7 = Export log complet
    if input.KeyCode == Enum.KeyCode.F7 then
        local out = "=== VERTEX SPY LOG (" .. #LOG .. " entrées) ===\n"
        out = out .. table.concat(LOG, "\n") .. "\n=== FIN LOG ==="
        print(out)
        if setclipboard then
            setclipboard(out)
            warn("[SPY] ✅ Log copié dans le presse-papier !")
        end
    end

    -- F8 = Résumé des techniques détectées
    if input.KeyCode == Enum.KeyCode.F8 then
        warn("\n╔═══ VERTEX SPY - RAPPORT FINAL ═══╗")
        warn(string.format("║ Tweens CFrame       : %d", STATS.tweenMoves))
        warn(string.format("║ CFrame directs      : %d  ← technique anti-rollback", STATS.directCframes))
        warn(string.format("║ Velocity resets     : %d  ← bloque les forces map", STATS.velocityReset))
        warn(string.format("║ Noclip toggles      : %d", STATS.noclipToggles))
        warn(string.format("║ firetouchinterest   : %d  ← collecte sans contact physique", STATS.touchFires))
        warn(string.format("║ Gravity changes     : %d", STATS.gravityChange))
        warn(string.format("║ Pièces collectées   : %d", STATS.coinCollected))
        warn("╠══════════════════════════════════╣")
        warn("║ TECHNIQUES DÉTECTÉES :")
        for tech, _ in pairs(TECHNIQUES) do
            warn("║  → " .. tech)
        end
        warn("╚══════════════════════════════════╝")
    end
end)

