local API_URL     = "https://cometkeyapi.netlify.app/verify"
local DISCORD_URL = "https://discord.gg/NkYSkdAkey"

local Players      = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local RunService   = game:GetService("RunService")
local HttpService  = game:GetService("HttpService")
local CoreGui      = game:GetService("CoreGui")
local Player       = Players.LocalPlayer

local function getHWID()
    if getmachineidentity then return tostring(getmachineidentity()) end
    if gethwid            then return tostring(gethwid())            end
    local ok, id = pcall(function()
        return game:GetService("RbxAnalyticsService"):GetClientId()
    end)
    if ok and id and id ~= "" then return id end
    return tostring(Player.UserId)
end

local function verifyKey(key, hwid)
    local url = API_URL .. "?key=" .. key .. "&hwid=" .. HttpService:UrlEncode(hwid)
    
    local ok, result = pcall(function()
        if type(request) == "function" then
            return request({Url = url, Method = "GET"}).Body
        elseif type(http_request) == "function" then
            return http_request({Url = url, Method = "GET"}).Body
        else
            return HttpService:GetAsync(url, true)
        end
    end)

    if not ok then return false, "Network Error (Request blocked)" end

    local data
    pcall(function() data = HttpService:JSONDecode(result) end)
    
    if not data then return false, "Invalid API response" end

    if data.valid then
        local info = data.bound
            and ("Device bound · " .. (data.expiresIn or "?") .. " mins remaining")
            or  ((data.expiresIn or "?") .. " mins remaining")
        return true, info
    end

    local reasons = {
        KEY_NOT_FOUND  = "Key not found",
        KEY_EXPIRED    = "Key expired — use /genkey",
        HWID_MISMATCH  = "HWID mismatch",
        NO_HWID        = "Missing HWID",
        NO_KEY         = "No key provided",
    }
    return false, reasons[data.reason] or (data.reason or "Unknown Error")
end

