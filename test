local Players           = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local player            = Players.LocalPlayer

local OK  = "✅"
local ERR = "❌"
local WRN = "⚠️"

local function log(icon, msg)
    print(icon .. "  " .. msg)
end

local function sep(title)
    print("\n========== " .. title .. " ==========")
end

-- ============================================================
--  1. BOOTHLOCATION
-- ============================================================
sep("BOOTHLOCATION")

local _boothlocation = nil

local ws_mapui = workspace:FindFirstChild("MapUI")
if ws_mapui then
    _boothlocation = ws_mapui
    log(OK, "workspace.MapUI trouvé → utilisé comme _boothlocation")
else
    log(ERR, "workspace.MapUI introuvable")
end

if not _boothlocation then
    local pg = player:FindFirstChild("PlayerGui")
    if pg then
        local container = pg:FindFirstChild("MapUIContainer")
        if container then
            local mapui = container:FindFirstChild("MapUI")
            if mapui then
                _boothlocation = mapui
                log(OK, "PlayerGui.MapUIContainer.MapUI trouvé → utilisé comme _boothlocation")
            else
                log(ERR, "PlayerGui.MapUIContainer.MapUI introuvable")
            end
        else
            log(ERR, "PlayerGui.MapUIContainer introuvable")
        end
    else
        log(ERR, "PlayerGui introuvable")
    end
end

if not _boothlocation then
    log(ERR, "FATAL: _boothlocation est nil — le script va serverHop immédiatement")
end

-- ============================================================
--  2. BOOTHUI
-- ============================================================
sep("BOOTHUI")

local boothUI = nil
if _boothlocation then
    boothUI = _boothlocation:FindFirstChild("BoothUI")
    if boothUI then
        log(OK, "BoothUI trouvé dans _boothlocation")
        local children = boothUI:GetChildren()
        log(OK, "Nombre de booths dans BoothUI: " .. #children)
        if #children > 0 then
            local first = children[1]
            log(OK, "Premier enfant: " .. first.Name)

            -- Vérif Details.Owner
            local details = first:FindFirstChild("Details")
            if details then
                log(OK, "Details trouvé")
                local owner = details:FindFirstChild("Owner")
                if owner then
                    log(OK, "Owner trouvé — Text = '" .. tostring(owner.Text) .. "'")
                else
                    log(ERR, "Owner introuvable dans Details")
                end
            else
                log(ERR, "Details introuvable dans " .. first.Name)
                log(WRN, "Enfants de " .. first.Name .. ":")
                for _, v in ipairs(first:GetChildren()) do
                    print("    → " .. v.Name .. " (" .. v.ClassName .. ")")
                end
            end

            -- Vérif Sign.TextLabel
            local sign = first:FindFirstChild("Sign")
            if sign then
                log(OK, "Sign trouvé")
                local tl = sign:FindFirstChild("TextLabel")
                if tl then
                    log(OK, "Sign.TextLabel trouvé — Text = '" .. tostring(tl.Text):sub(1,40) .. "'")
                else
                    log(ERR, "Sign.TextLabel introuvable")
                    log(WRN, "Enfants de Sign:")
                    for _, v in ipairs(sign:GetChildren()) do
                        print("    → " .. v.Name .. " (" .. v.ClassName .. ")")
                    end
                end
            else
                log(ERR, "Sign introuvable dans " .. first.Name)
            end
        end
    else
        log(ERR, "BoothUI introuvable dans _boothlocation")
        log(WRN, "Enfants de _boothlocation:")
        for _, v in ipairs(_boothlocation:GetChildren()) do
            print("    → " .. v.Name .. " (" .. v.ClassName .. ")")
        end
    end
else
    log(ERR, "Skip — _boothlocation nil")
end

-- ============================================================
--  3. BOOTHINTERACTIONS
-- ============================================================
sep("BOOTHINTERACTIONS")

local boothInteractions = workspace:FindFirstChild("BoothInteractions")
if boothInteractions then
    log(OK, "workspace.BoothInteractions trouvé")
    local children = boothInteractions:GetChildren()
    log(OK, "Nombre d'interactions: " .. #children)
    if #children > 0 then
        local first = children[1]
        log(OK, "Premier enfant: " .. first.Name .. " (" .. first.ClassName .. ")")
        local slot = first:GetAttribute("BoothSlot")
        if slot then
            log(OK, "Attribute 'BoothSlot' trouvé = " .. tostring(slot))
        else
            log(ERR, "Attribute 'BoothSlot' introuvable sur " .. first.Name)
            log(WRN, "Attributes disponibles:")
            for k, v in pairs(first:GetAttributes()) do
                print("    → " .. k .. " = " .. tostring(v))
            end
        end
    end
else
    log(ERR, "workspace.BoothInteractions introuvable")
    log(WRN, "Enfants de workspace contenant 'Booth':")
    for _, v in ipairs(workspace:GetChildren()) do
        if v.Name:lower():find("booth") then
            print("    → " .. v.Name .. " (" .. v.ClassName .. ")")
        end
    end
end

-- ============================================================
--  4. REMOTES
-- ============================================================
sep("REMOTES (ReplicatedStorage)")

local Remotes = nil
log(OK, "Scan de ReplicatedStorage...")
for _, v in pairs(ReplicatedStorage:GetChildren()) do
    print("    → " .. v.Name .. " (" .. v.ClassName .. ")")
    if v.Name:find("Remote") and v:IsA("ModuleScript") then
        log(OK, "ModuleScript contenant 'Remote' trouvé: " .. v.Name)
        local ok, result = pcall(function() return require(v) end)
        if ok and result then
            log(OK, "require() OK")
            Remotes = result

            -- Test Event
            local okEv, evResult = pcall(function() return result.Event end)
            if okEv and evResult then
                log(OK, "result.Event existe")

                -- Test ClaimBooth
                local okCB = pcall(function() return result.Event("ClaimBooth") end)
                log(okCB and OK or ERR, "Event('ClaimBooth') " .. (okCB and "accessible" or "ERREUR"))

                -- Test SetCustomization
                local okSC = pcall(function() return result.Event("SetCustomization") end)
                log(okSC and OK or ERR, "Event('SetCustomization') " .. (okSC and "accessible" or "ERREUR"))

                -- Test SetAnonymousLive
                local okAL = pcall(function() return result.Event("SetAnonymousLive") end)
                log(okAL and OK or ERR, "Event('SetAnonymousLive') " .. (okAL and "accessible" or "ERREUR"))
            else
                log(ERR, "result.Event introuvable ou erreur")
            end
        else
            log(ERR, "require() ECHEC: " .. tostring(result))
        end
    end
end

if not Remotes then
    log(ERR, "FATAL: Aucun Remote ModuleScript trouvé — booth claim et text update impossibles")
end

-- ============================================================
--  5. LEADERSTATS
-- ============================================================
sep("LEADERSTATS")

local ls = player:FindFirstChild("leaderstats")
if ls then
    log(OK, "leaderstats trouvé")
    local raised = ls:FindFirstChild("Raised")
    if raised then
        log(OK, "Raised trouvé — Value = " .. tostring(raised.Value))
    else
        log(ERR, "Raised introuvable dans leaderstats")
        log(WRN, "Enfants de leaderstats:")
        for _, v in ipairs(ls:GetChildren()) do
            print("    → " .. v.Name .. " (" .. v.ClassName .. ") = " .. tostring(v.Value))
        end
    end
else
    log(ERR, "leaderstats introuvable sur le joueur")
end

-- ============================================================
--  RÉSUMÉ
-- ============================================================
sep("RÉSUMÉ")
log(_boothlocation and OK or ERR, "_boothlocation: " .. (_boothlocation and "OK" or "NIL"))
log(boothUI and OK or ERR,        "BoothUI: " .. (boothUI and "OK" or "NIL"))
log(boothInteractions and OK or ERR, "BoothInteractions: " .. (boothInteractions and "OK" or "NIL"))
log(Remotes and OK or ERR,        "Remotes: " .. (Remotes and "OK" or "NIL"))
print("\nDiagnostic terminé. Copie tout ce qui est affiché et envoie-le.")
