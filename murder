local function getRoleColorByName(roleName)
    if RoleColorMap[roleName] then return RoleColorMap[roleName] end
    return FALLBACK_COLORS[roleName] or Color3.fromRGB(255, 255, 255)
end

local function scanPayloadForRoles(t, depth)
    if type(t) ~= "table" then return end
    depth = depth or 0
    if depth > 5 then return end
    for k, v in pairs(t) do
        if type(v) == "string" and ROLES[v] then
            PlayerRoleCache[tostring(k)] = v
        elseif type(v) == "table" then
            if type(v.Role) == "string" and ROLES[v.Role] then
                PlayerRoleCache[tostring(k)] = v.Role
                if v.Dead ~= nil then PlayerDeadCache[tostring(k)] = (v.Dead == true) end
            else
                scanPayloadForRoles(v, depth + 1)
            end
        end
    end
end

local function fetchAllRoles()
    local ok, data = pcall(function() return GetPlayerDataFn:InvokeServer() end)
    if not ok or type(data) ~= "table" then return end
    for name, pdata in pairs(data) do
        if type(pdata) == "table" and pdata.Role then
            PlayerRoleCache[tostring(name)] = tostring(pdata.Role)
            if pdata.Dead ~= nil then PlayerDeadCache[tostring(name)] = (pdata.Dead == true) end
        end
    end
end

local function isPlayerAlive()
    local char = Player.Character
    if not char then return false end
    local hum = char:FindFirstChildOfClass("Humanoid")
    return hum and hum.Health > 0
end

local function onCharacterAdded(char)
    local hum = char:WaitForChild("Humanoid", 5)
    if not hum then return end
    hum.Died:Connect(function()
        IsParticipating = false; AutofarmIN = false
    end)
end
Player.CharacterAdded:Connect(onCharacterAdded)
if Player.Character then onCharacterAdded(Player.Character) end

