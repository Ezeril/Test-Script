local function rgb(hexStr)
    hexStr = hexStr:gsub("#","")
    local r = tonumber("0x"..hexStr:sub(1,2)) or 255
    local g = tonumber("0x"..hexStr:sub(3,4)) or 255
    local b = tonumber("0x"..hexStr:sub(5,6)) or 255
    return Color3.fromRGB(r,g,b)
end

local function formatNumber(n)
    if n == 420 or n == 425 then n = n + 10 end
    if n >= 10000 then return string.format("%.1fk", n/1000)
    elseif n >= 1000 then return string.format("%.2fk", n/1000)
    else return tostring(n) end
end

local function splitString(s)
    local t = {}
    for str in string.gmatch(s,"([^,]+)") do
        table.insert(t, str:match("^%s*(.-)%s*$"))
    end
    return t
end

local function twn(obj, props, t, style, dir)
    local tw = TweenService:Create(obj, TweenInfo.new(t or 0.2, style or Enum.EasingStyle.Quart, dir or Enum.EasingDirection.Out), props)
    tw:Play(); return tw
end

