local function makeToggle(parent, text, order, default, callback)
    local btn = Instance.new("TextButton",parent)
    btn.LayoutOrder      = order
    btn.Size             = UDim2.new(1,0,0,38)
    btn.BackgroundColor3 = C.card
    btn.Text             = "  "..text
    btn.TextColor3       = C.text
    btn.Font             = Enum.Font.GothamSemibold
    btn.TextSize         = 13
    btn.TextXAlignment   = Enum.TextXAlignment.Left
    corner(btn,9); stroke(btn,C.divider,1)

    local dot = Instance.new("Frame",btn)
    dot.Size             = UDim2.new(0,8,0,8)
    dot.Position         = UDim2.new(1,-18,0.5,-4)
    dot.BackgroundColor3 = default and C.toggleOn or C.toggleOff
    corner(dot,8)

    local active = default
    if active then twn(btn,{BackgroundColor3=Color3.fromRGB(40,40,40), TextColor3=C.white}) end

    btn.MouseButton1Click:Connect(function()
        active = not active
        twn(dot,{BackgroundColor3 = active and C.toggleOn or C.toggleOff})
        twn(btn,{BackgroundColor3 = active and Color3.fromRGB(40,40,40) or C.card,
                 TextColor3       = active and C.white or C.text})
        callback(active)
    end)
    btn.MouseEnter:Connect(function() if not active then twn(btn,{BackgroundColor3=C.cardHover}) end end)
    btn.MouseLeave:Connect(function() if not active then twn(btn,{BackgroundColor3=C.card}) end end)
    return btn, function(v)
        active = v
        twn(dot,{BackgroundColor3 = active and C.toggleOn or C.toggleOff})
        twn(btn,{BackgroundColor3 = active and Color3.fromRGB(40,40,40) or C.card,
                 TextColor3       = active and C.white or C.text})
    end
end

local function makeDropdown(parent, label, order, options, current, callback)
    local holder = Instance.new("Frame",parent)
    holder.LayoutOrder      = order
    holder.Size             = UDim2.new(1,0,0,38)
    holder.BackgroundColor3 = C.card
    corner(holder,9); stroke(holder,C.divider,1)

    local lbl = Instance.new("TextLabel",holder)
    lbl.Size            = UDim2.new(0.5,0,1,0)
    lbl.Position        = UDim2.new(0,10,0,0)
    lbl.BackgroundTransparency = 1
    lbl.Text            = label
    lbl.TextColor3      = C.subtext
    lbl.Font            = Enum.Font.GothamSemibold
    lbl.TextSize        = 12
    lbl.TextXAlignment  = Enum.TextXAlignment.Left

    local val = Instance.new("TextButton",holder)
    val.Size            = UDim2.new(0.45,0,0.7,0)
    val.Position        = UDim2.new(0.52,0,0.15,0)
    val.BackgroundColor3 = C.cardHover
    val.Text            = tostring(current or (options[1] or ""))
    val.TextColor3      = C.white
    val.Font            = Enum.Font.GothamBold
    val.TextSize        = 12
    corner(val,7)

    local idx = 1
    for i, v in ipairs(options) do if v == current then idx = i end end

    val.MouseButton1Click:Connect(function()
        idx = (idx % #options) + 1
        val.Text = options[idx]
        callback(options[idx])
    end)
    return holder, val
end

