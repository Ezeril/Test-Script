local function fetchNearPlr()
    local lChar = player.Character
    if not lChar then return nil end
    local hum = lChar:FindFirstChildOfClass("Humanoid")
    if not (hum and hum.RootPart) then return nil end
    local minMag, found = 9999999, nil
    for _, v in next, Players:GetPlayers() do
        if v == player then continue end
        local c = v.Character
        if c and c:FindFirstChildOfClass("Humanoid") and c:FindFirstChildOfClass("Humanoid").RootPart then
            local mag = (c:FindFirstChildOfClass("Humanoid").RootPart.Position - hum.RootPart.Position).Magnitude
            if mag < minMag then minMag = mag; found = v end
        end
    end
    return found
end

